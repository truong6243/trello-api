{
  "name": "nodejs-expressjs-mongodb-base-project",
  "private": true,
  "version": "1.0.0",
  "author": "TruongLamDev",
  "engines": {
    "node": ">=18.x"
  },
  "scripts": {
    "lint": "eslint src --ext js --report-unused-disable-directives --max-warnings 0",
    "clean": "node -e \"require('fs').rmSync('build', { recursive: true, force: true }); require('fs').mkdirSync('build', { recursive: true });\"",
    "build-babel": "./node_modules/.bin/babel ./src -d ./build/src",
    "build": "npm run clean && npm run build-babel",
    "production": "npm run build && cross-env BUILD_MODE=production node ./build/src/server.js",
    "dev": "cross-env BUILD_MODE=dev nodemon --exec babel-node ./src/server.js"
  },
  "dependencies": {
    "@babel/cli": "^7.22.10",
    "@babel/core": "^7.22.10",
    "@babel/plugin-transform-runtime": "^7.22.10",
    "@babel/preset-env": "^7.22.10",
    "@babel/runtime": "^7.22.10",
    "@getbrevo/brevo": "^2.0.0-beta.4",
    "async-exit-hook": "^2.0.1",
    "babel-plugin-module-resolver": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.18.1",
    "mailersend": "^2.8.0",
    "mongodb": "^6.21.0",
    "ms": "^2.1.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.22.10",
    "@babel/node": "^7.22.10",
    "eslint": "^8.47.0",
    "nodemon": "^3.0.1",
    "rimraf": "^6.1.3"
  }
}
